# Copy to .env.local for local dev. For production, set these in your host (e.g. GitHub Actions secrets → build env).

# Supabase (https://supabase.com) — create a project, run supabase/schema.sql, enable Google provider.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Comma-separated domains allowed to use /admin after Google sign-in (must match RLS in schema.sql).
VITE_ALLOWED_EMAIL_DOMAINS=criminallydevdads.com

# Legacy catalog discovery (when site_games is empty or Supabase not set)
VITE_GITHUB_REPO_OWNER=CDDdrifter
VITE_GITHUB_REPO_NAME=criminallydevdads.com
