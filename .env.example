# === LOCAL DEV ONLY (.env.local) ============================================
#
# ".env.local" is a plain text file YOU create in the repo root (next to package.json).
# It is NOT uploaded to GitHub (.gitignore). Vite loads it when you run: npm run dev
#
# How to create it (Windows):
#   1. In File Explorer, open your criminallydevdads.com folder.
#   2. Right-click → New → Text Document → name it:  .env.local
#      (If Windows hides extensions, name it .env.local and confirm when warned.)
#   3. Open in Notepad. Paste the VITE_* lines below (uncomment and fill real values from Supabase → Settings → API).
#
# LIVE SITE (what visitors use): put the same two names in GitHub → Settings → Secrets → Actions, then redeploy.
# ============================================================================
#
# You do NOT need Supabase to ship the site: see docs/WEBSITE_WORKFLOW.md (Path A = games.json + games/).

# Game list: auto (default) = use DB if site_games has rows, else games.json | legacy = always files | cms = DB only
# VITE_GAME_CATALOG=auto

# Supabase — optional; only for /#/admin CMS. Leave unset in GitHub Actions to build file-only catalog.
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key

# Show "Team login" / "Admin" in the top nav (default: hidden). Open /#/admin directly anytime.
# VITE_SHOW_ADMIN_NAV=true

# Legacy catalog / asset URLs (GitHub raw or Pages)
VITE_GITHUB_REPO_OWNER=CDDdrifter
VITE_GITHUB_REPO_NAME=criminallydevdads.com
